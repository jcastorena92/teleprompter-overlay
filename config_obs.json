{
    "window_title": "Teleprompter OBS",
    "width": 1000,
    "height": 600,
    "bg_color": "black",
    "fg_color": "white",
    "font_family": "Arial",
    "font_size": 28,
    "min_font_size": 20,
    "text_width": 260,
    "always_on_top": true,
    "transparency": 1.0,
    "scroll_interval_ms": 30,
    "scroll_step": 1.2,
    "initial_speed": 0.7,
    "start_running": false,
    "show_status_bar": true,
    "status_bar_position": "bottom",
    "auto_hide_status_bar": true,
    "status_bar_hide_ms": 1800,
    "top_spacer": 40,
    "reading_window_lines": 2,
    "line_height_factor": 1.35,
    "reading_window_offset_y": -180,
    "ghost_mode": true,
    "ghost_window_width": 300,
    "dim_color": "black",
    "show_guide_line": true,
    "guide_line_color": "#505050",
    "guide_line_width": 1,
    "guide_line_offset_y": 0
}